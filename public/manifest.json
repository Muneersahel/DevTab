{
  "manifest_version": 3,
  "name": "DevTab",
  "description": "A focused developer new-tab dashboard powered by WakaTime.",
  "version": "0.2.0",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["storage", "search"],
  "host_permissions": ["https://api.wakatime.com/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
